# LLM configuration
# Ollama OpenAI-compatible endpoint:
LLM_BASE_URL=http://localhost:11434/v1
# For remote providers, set the provider base URL and API key, for example:
# LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b

# Maximum tool-calling turns per answer
OLLAMA_MAX_TURNS=25

# Security
# Production must use a random value with at least 32 characters.
JWT_SECRET=change-this-to-a-random-secret-string-at-least-32-chars
JWT_EXPIRES_IN=24h

# Server
PORT=8080
# Comma-separated allowed origins. Leave empty when serving the UI from this same server.
CORS_ORIGIN=
# Set to true/1 when running behind a trusted reverse proxy.
TRUST_PROXY=false

# Initial admin account. Change ADMIN_PASSWORD before production deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# Storage
STORAGE_PATH=./storage
DB_PATH=./data/enterprise-kb.db

# Optional login rate limits
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=10
