{
  "name": "enterprise-kb",
  "version": "1.0.0",
  "description": "Enterprise knowledge base with OpenAI-compatible LLM support, multi-user auth, and document management",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "npx tsx src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run build && npm run test && npm audit --omit=dev --audit-level=moderate",
    "codex:smoke": "node scripts/codex-smoke.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "claude-tools-kit": "file:packages/claude-tools-kit",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
